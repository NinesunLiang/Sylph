{
  "statusLine": {
    "type": "command",
    "command": ".claude/hooks/hook-launcher.sh statusline-command.sh"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh userprompt-level-hint.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh userprompt-prompt-collector.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh pretool-sensitive-edit.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh pretool-verify-gate.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh pretool-action-gate.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh pretool-fallback-check.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh pretool-plan-gate.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh pretool-edit-scope.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh pretool-oracle-gate.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh posttool-audit.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh posttool-output-compress.py"
          },
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh posttool-archive-check.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/hook-launcher.sh posttool-completion-gate.py"
          }
        ]
      }
    ]
  }
}
