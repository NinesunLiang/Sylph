{
  "statusLine": {
    "type": "command",
    "command": ".claude/hooks/statusline-command.sh"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/userprompt-level-hint.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/userprompt-session-resume.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/userprompt-compact-writer.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-sensitive-edit.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-action-gate.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-fallback-check.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-plan-gate.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-edit-scope.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/posttool-audit.py"
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/posttool-completion-gate.py"
          }
        ]
      }
    ]
  }
}
