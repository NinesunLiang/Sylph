{
  "env": {
    "ANTHROPIC_AUTH_TOKEN": "sk-Xrwon2jxfgUlOlYCM2wLVcaMlT2ZkMnOjUZtivyuaFvP5r4F",
    "ANTHROPIC_BASE_URL": "https://api.moonshot.cn/anthropic",
    "ANTHROPIC_MODEL": "kimi-k3",
    "ANTHROPIC_DEFAULT_OPUS_MODEL": "kimi-k3",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "kimi-k3",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "kimi-k3",
    "CLAUDE_CODE_SUBAGENT_MODEL": "kimi-k3",
    "ENABLE_TOOL_SEARCH": "false",
    "CLAUDE_CODE_AUTO_COMPACT_WINDOW": "1048576"
  },
  "enabledPlugins": {
    "pyright-lsp@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true,
  "model": "opus",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash|Delete",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/hook-launcher.sh\" \"pretool-gate.py\""
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit|NotebookEdit|Bash|Delete",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".claude/hooks/hook-launcher.sh\" \"carroros-night-deny.py\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \".claude/hooks/pretool-user-approve.py\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \".claude/hooks/posttool-gate.py\"",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \".claude/hooks/session-start.py\"",
            "timeout": 3000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 \".claude/hooks/stop-flywheel.py\"",
            "timeout": 10000
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \".claude/hooks/statusline-command.sh\""
  }
}
