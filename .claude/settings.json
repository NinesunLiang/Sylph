{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "disableAllHooks": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/pretool-oracle-gate.py",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-oracle-gate.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/edit-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-edit-lsp-check.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/permission-gate.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-retry-check.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-blast-radius.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash|Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/privacy-gate.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/context-guard.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-edit-scope.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-ask-guard.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lsp-suggest.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-write-lock.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/subagent-guard.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-sensitive-edit.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/fuzzy-block.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-completion-gate.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-plan-gate.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-terminal-safety.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-usage-tracker.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/completion-gate.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-handoff-writer.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-completion-audit.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "TaskUpdate|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-format-gate.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "TaskUpdate|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-anti-pattern-detect.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-bash-audit.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-write-cite.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/read-tracker.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-snapshot.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/error-dna.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/token_writer.sh",
            "timeout": 3000
          },
          {
            "command": "python .claude/hooks/meta-oracle-trigger.py",
            "hookName": "meta-oracle-trigger",
            "type": "command",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/meta-oracle-trigger.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-edit-quality.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-write-lock.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-subagent-audit.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-claim-audit.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/intent-tracker.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/build-validator.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/error-dna.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-bash-audit.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/build-validator.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/context-compressor.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-project-knowledge.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/flywheel-report.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/token_writer.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/ecosystem-probe.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-resume.sh",
            "timeout": 10000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/lucas.liang/Desktop/Sylph/Carror_OS/.claude/hooks/auto-snapshot.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/lucas.liang/Desktop/Sylph/Carror_OS/.claude/hooks/stop-drain.sh",
            "timeout": 10000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/lucas.liang/Desktop/Sylph/Carror_OS/.claude/hooks/skill-flywheel.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash /Users/lucas.liang/Desktop/Sylph/Carror_OS/.claude/hooks/knowledge-condenser.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-user-correction.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/turn-counter.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/compact-detect.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "hooks": []
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-rules-inject.sh",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "env": {
    "ANTHROPIC_MODEL": "deepseek-v4-pro[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek-v4-pro[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-v4-pro[1m]"
  },
  "permissions": {
    "defaultMode": "bypassPermissions"
  },
  "effortLevel": "high"
}