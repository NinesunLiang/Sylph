{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "disableAllHooks": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-oracle-gate.py",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-oracle-gate.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/edit-guard.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-edit-lsp-check.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-purify-gate.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-skill-version-guard.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/context-guard.py",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-write-lock.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-sensitive-file-guard.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-b1-detect.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-edit-scope.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/workflow-standard/hooks/pretool-workflow-gate",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-scope-gate.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/edit-guard.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-plan-gate.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-sensitive-edit.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Edit|Write|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-sensitive-edit.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-plan-gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-edit-scope.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/permission-gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-retry-check.py",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-blast-radius.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-terminal-safety.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-git-gate.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/permission-gate.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash|Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/privacy-gate.py",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/context-guard.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre-ask-guard.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-ask-guard.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/lsp-suggest.py",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/lsp-suggest.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/subagent-guard.py",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre-completion-gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pre-completion-gate.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-node-reference.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/fuzzy-block.py",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/fuzzy-block.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-skill-body-enforce.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-snapshot.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-edit-quality.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-write-lock.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-claim-audit.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/intent-tracker.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-write-cite.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/completion-gate.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-handoff-writer.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-completion-audit.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-checkpoint.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/workflow-standard/hooks/checkpoint",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "TaskUpdate|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-format-gate.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-anti-pattern-detect.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-template-check.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/phase-state-tracker.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/read-tracker.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-read-cite.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-bash-audit.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/error-dna.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/build-validator.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-usage-tracker.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-skill-compliance.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Task|Agent",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-subagent-audit.sh",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/token_writer.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/meta-oracle-trigger.py",
            "hookName": "meta-oracle-trigger",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/meta-oracle-trigger.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/agentic-ui.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/permission-frequency-tracker.sh",
            "timeout": 3000
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/error-dna.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-bash-audit.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/build-validator.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/lsp-gate.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/oracle-gate.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/context-compressor.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/knowledge-condenser.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/error-dna-auto-fix.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/scripts/meta-oracle-review.py --check-readiness",
            "timeout": 20000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/inject-project-knowledge.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/flywheel-report.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/token_writer.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-cruise-check.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/ecosystem-probe.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/session-resume.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash .claude/workflow-standard/hooks/state-recovery",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/workflow-standard/hooks/session-inject",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/cross-platform-smoke-test.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/auto-snapshot.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/skill-flywheel.sh",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/stop-drain.sh",
            "timeout": 10000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/posttool-checkpoint.sh",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-user-correction.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/turn-counter.sh",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-approve-detect.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/thinking-gate.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/pretool-rules-inject.sh",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/pretool-python-bridge.sh context-inject",
            "timeout": 3000
          }
        ]
      }
    ]
  },
  "env": {
    "ANTHROPIC_MODEL": "deepseek-v4-pro[1m]",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "deepseek-v4-pro[1m]",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "deepseek-v4-pro[1m]",
    "CLAUDE_CODE_MAX_CONTEXT_TOKENS": "1000000"
  },
  "permissions": {
    "defaultMode": "default"
  },
  "effortLevel": "high"
}