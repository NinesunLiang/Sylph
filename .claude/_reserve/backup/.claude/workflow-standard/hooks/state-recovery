#!/usr/bin/env bash
# workflow-standard/hooks/state-recovery — 状态腐蚀恢复 + Gate 超时检测
# 注册: SessionStart（在 session-inject 之前运行）
# 依赖: harness_config.sh, workflow-state.json

set -u
source "$(dirname "$0")/../../.claude/hooks/harness_config.sh" 2>/dev/null || true

STATE_FILE="${HOME}/.claude/state/workflow-state.json"
[ -f ".claude/state/workflow-state.json" ] && STATE_FILE=".claude/state/workflow-state.json"

[ -f "$STATE_FILE" ] || exit 0
command -v python3 &>/dev/null || exit 0

# ─── 腐蚀检测 ───
if ! python3 -c "import json; json.load(open('$STATE_FILE'))" 2>/dev/null; then
    BACKUP="${STATE_FILE}.corrupted.$(date +%Y%m%d-%H%M%S)"
    cp "$STATE_FILE" "$BACKUP" 2>/dev/null

    python3 -c "
import json, os
reset = {
    'active': False, 'task_id': None, 'task_level': None, 'stage': 'idle',
    'stages': {},
    'constraint_matrix': {'allowed_files': [], 'forbidden_patterns': [], 'max_files': 20},
    'checkpoints': [], 'blocked_items': [],
    'roi_estimate': {}, 'roi_actual': {},
    'audit_log': [{
        'event': 'corruption_recovery', 'backup': '''$BACKUP''',
        'detail': 'JSON corrupted — reset to inactive'
    }]
}
with open('$STATE_FILE', 'w') as f: json.dump(reset, f, indent=2, ensure_ascii=False)
" 2>/dev/null

    echo "[WORKFLOW RECOVERY] 状态文件已损坏 — 已备份至 $BACKUP — 已重置为 inactive" >&2
    flywheel_event "workflow_recovery" "corruption" "P0" "reset" 2>/dev/null || true
    exit 0
fi

# ─── Gate 超时检测 ───
python3 -c "
import json, os
from datetime import datetime, timezone, timedelta
CST = timezone(timedelta(hours=8))

with open('$STATE_FILE') as f: s = json.load(f)
if not s.get('active'): raise SystemExit

stage = s.get('stage','idle')
if stage not in ('gate1','gate2','gate3'): raise SystemExit

audit = s.get('audit_log',[])
if not audit: raise SystemExit

last_ts = audit[-1].get('timestamp','')
if not last_ts: raise SystemExit

try: last_time = datetime.fromisoformat(last_ts)
except: raise SystemExit

elapsed = (datetime.now(CST) - last_time).total_seconds() / 60
threshold = s.get('gate_timeouts',{}).get(f'{stage}_timeout_minutes', 60)

if elapsed > threshold:
    s['active'] = False
    s['stage'] = 'idle'
    s['audit_log'].append({
        'event': 'gate_timeout', 'stage': stage,
        'elapsed_minutes': round(elapsed, 1),
        'detail': f'Gate timed out after {elapsed:.0f}min'
    })
    os.rename('$STATE_FILE', '$STATE_FILE.bak')
    with open('$STATE_FILE', 'w') as f: json.dump(s, f, indent=2, ensure_ascii=False)
    print(f'GATE_TIMEOUT:{stage}:{elapsed:.0f}min', file=__import__('sys').stderr)
" 2>/dev/null

flywheel_event "workflow_recovery" "gate_timeout_check" "L1" "checked" 2>/dev/null || true
exit 0
