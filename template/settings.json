{
  "disableAllHooks": false,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "python3 .claude/hooks/permission-gate.py", "timeout": 5000 },
          { "type": "command", "command": "python3 .claude/hooks/privacy-gate.py", "timeout": 3000 },
          { "type": "command", "command": "python3 .claude/hooks/fuzzy-block.py", "timeout": 3000 },
          { "type": "command", "command": "python3 .claude/hooks/pretool-retry-check.py", "timeout": 3000 }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "python3 .claude/hooks/pretool-plan-gate.py", "timeout": 5000 }
        ]
      },
      {
        "matcher": "delegate_task",
        "hooks": [
          { "type": "command", "command": "python3 .claude/hooks/subagent-guard.py", "timeout": 3000 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          { "type": "command", "command": "python3 .claude/hooks/completion-gate.py", "timeout": 3000 },
          { "type": "command", "command": "python3 .claude/hooks/skill-flywheel.py", "timeout": 10000 },
          { "type": "command", "command": "python3 .claude/hooks/meta-oracle-trigger.py", "timeout": 5000 }
        ]
      }
    ]
  }
}
