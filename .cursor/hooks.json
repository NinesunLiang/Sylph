{
  "hooks": {
    "beforeShellExecution": [
      {
        "type": "command",
        "command": "bash .claude/hooks/permission-gate.sh",
        "timeout": 5,
        "description": "拦截危险命令（rm -rf / git push --force / sudo）"
      },
      {
        "type": "command",
        "command": "bash .claude/hooks/privacy-gate.sh",
        "timeout": 3,
        "description": "拦截密钥文件读取和明文 Token"
      },
      {
        "type": "command",
        "command": "bash .claude/hooks/fuzzy-block.sh",
        "timeout": 3,
        "description": "模糊指令硬阻断（C1 指令清晰度门禁）"
      },
      {
        "type": "command",
        "command": "bash .claude/hooks/pretool-terminal-safety.sh",
        "timeout": 3,
        "description": "终端命令格式校验"
      }
    ],
    "afterShellExecution": [
      {
        "type": "command",
        "command": "bash .claude/hooks/posttool-bash-audit.sh",
        "timeout": 5,
        "description": "记录所有 bash 执行到审计日志"
      },
      {
        "type": "command",
        "command": "bash .claude/hooks/build-validator.sh",
        "timeout": 5,
        "description": "编译/测试失败时自动记录到 error-dna"
      },
      {
        "type": "command",
        "command": "bash .claude/hooks/error-dna.sh",
        "timeout": 3,
        "description": "错误模式积累"
      }
    ],
    "beforeFileWrite": [
      {
        "type": "command",
        "command": "bash .claude/hooks/context-guard.sh",
        "timeout": 3,
        "description": "上下文占比超阈值时阻断写入"
      },
      {
        "type": "command",
        "command": "bash .claude/hooks/pretool-sensitive-file-guard.sh",
        "timeout": 3,
        "description": "保护门禁文件不被 AI 直接写入"
      }
    ],
    "afterFileWrite": [
      {
        "type": "command",
        "command": "bash .claude/hooks/auto-snapshot.sh",
        "timeout": 5,
        "description": "文件变更后自动快照"
      },
      {
        "type": "command",
        "command": "bash .claude/hooks/posttool-write-cite.sh",
        "timeout": 3,
        "description": "检查写入内容是否有 file:line 来源引用"
      }
    ]
  }
}
