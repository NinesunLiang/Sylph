#!/usr/bin/env bash
# workflow-standard/hooks/checkpoint — 工作流 checkpoint 自动推进
# 注册: PostToolUse:TaskUpdate
# 依赖: harness_config.sh, workflow-state.json

set -u
source "$(dirname "$0")/../../.claude/hooks/harness_config.sh" 2>/dev/null || true

STATE_FILE="${HOME}/.claude/state/workflow-state.json"
[ -f ".claude/state/workflow-state.json" ] && STATE_FILE=".claude/state/workflow-state.json"

[ -f "$STATE_FILE" ] || { echo "continue"; exit 0; }
command -v python3 &>/dev/null || { echo "continue"; exit 0; }

ACTIVE=$(python3 -c "import json; s=json.load(open('$STATE_FILE')); print(s.get('active',False))" 2>/dev/null)
[ "$ACTIVE" = "True" ] || { echo "continue"; exit 0; }

STAGE=$(python3 -c "import json; s=json.load(open('$STATE_FILE')); print(s.get('stage','idle'))" 2>/dev/null)
[ "$STAGE" = "executing" ] || { echo "continue"; exit 0; }

DESCRIPTION="${1:-}"
[ -n "$DESCRIPTION" ] || { echo "continue"; exit 0; }

# 检测 checkpoint 标记
CP=$(echo "$DESCRIPTION" | grep -oP '\[CHECKPOINT:\s*\K[^\]]+' | head -1)
[ -n "$CP" ] || { echo "continue"; exit 0; }

python3 -c "
import json, os
from datetime import datetime, timezone, timedelta
CST = timezone(timedelta(hours=8))

with open('$STATE_FILE') as f: s = json.load(f)
existing = [c for c in s.get('checkpoints',[]) if c.get('name') == '''$CP''']
if existing:
    existing[0]['updated_at'] = datetime.now(CST).isoformat()
else:
    s.setdefault('checkpoints',[]).append({'name': '''$CP''', 'status': 'completed', 'completed_at': datetime.now(CST).isoformat()})
os.rename('$STATE_FILE', '$STATE_FILE.bak')
with open('$STATE_FILE', 'w') as f: json.dump(s, f, indent=2, ensure_ascii=False)
" 2>/dev/null

flywheel_event "workflow_checkpoint" "$CP" "L1" "checkpointed" 2>/dev/null || true
echo "continue"
exit 0
