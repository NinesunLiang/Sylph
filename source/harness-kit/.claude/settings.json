{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "disableAllHooks": false,
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/session-resume.py",
            "timeout": 10000
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/edit-guard.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-edit-scope.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/permission-gate.py",
            "timeout": 5000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-retry-check.py",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash|Read|Grep",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/privacy-gate.py",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre-ask-guard.py",
            "timeout": 5000
          }
        ]
      },
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pre-completion-gate.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TaskUpdate",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/completion-gate.py",
            "timeout": 10000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/error-dna.py",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/posttool-error-dna-shard.py",
            "timeout": 5000
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-user-correction.py",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/turn-counter.py",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-approve-detect.py",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/thinking-gate.py",
            "timeout": 3000
          },
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-rules-inject.py",
            "timeout": 3000
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .claude/hooks/pretool-compact-writer.py",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
